# TradingView AI Copilot — Environment Configuration
# Copy this to .env and fill in your values

# Groq API key for vision analysis
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Stripe secret key (test mode for development)
# Get one at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe webhook secret (for verifying webhook signatures)
# Set up a webhook endpoint in Stripe Dashboard pointing to /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# CORS origin — the TradingView domain the extension runs on
CORS_ORIGIN=https://www.tradingview.com

# Server port
PORT=3001
